# apps/web/.env.local.example
# Copy this file to .env.local and fill in the values

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:password@localhost:5432/easy_access

# NextAuth.js v5 — generate a secret: openssl rand -base64 32
AUTH_SECRET=your-secret-here-run-openssl-rand-base64-32

# Server settings
PORT=3000
HOSTNAME=localhost
