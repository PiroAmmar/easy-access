# hub/.env.local.example
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT: copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local
#
# RAILWAY DEPLOYMENT: do NOT upload this file. Instead set each variable below
# in your Railway service → Variables tab.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──────────────────────────────────────────────────────
# Local dev: `docker compose up -d` starts Postgres on port 5434 with these
# exact credentials, so the value below works as-is.
# Railway: add a PostgreSQL database to your project, then set this to the
# reference variable: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://postgres:postgres@localhost:5434/easy_access

# ── Auth (REQUIRED) ──────────────────────────────────────────────────────────
# Secret used to sign session tokens (NextAuth v5).
# Generate one with:  openssl rand -base64 32
#   (or in PowerShell: [Convert]::ToBase64String((1..32 | % { Get-Random -Max 256 })))
AUTH_SECRET=replace-me-run-openssl-rand-base64-32

# Required when running behind a proxy (Railway). Harmless locally.
AUTH_TRUST_HOST=true

# ── Admin account (REQUIRED in production) ───────────────────────────────────
# The hub creates/updates this admin account automatically on startup.
# If unset, it falls back to admin/admin — fine locally, dangerous in prod.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# ── Server (optional) ────────────────────────────────────────────────────────
# Railway injects PORT automatically — don't set it there.
PORT=3000
# Bind address. Keep 0.0.0.0 for Railway/containers; localhost is fine for dev.
HOSTNAME=0.0.0.0
